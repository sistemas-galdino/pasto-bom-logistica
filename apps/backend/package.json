{
  "name": "@pastobom/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "main": "./src/index.ts",
  "scripts": {
    "dev": "node --experimental-strip-types --watch src/index.ts",
    "dev:worker": "node --experimental-strip-types --watch src/worker/scheduler.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@pastobom/shared": "*",
    "@supabase/supabase-js": "^2.45.0",
    "fastify": "^4.28.0",
    "node-cron": "^3.0.3",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/node-cron": "^3.0.11",
    "typescript": "^5.5.0"
  }
}
